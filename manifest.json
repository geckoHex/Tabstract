{
  "manifest_version": 3,
  "name": "Tabstract",
  "version": "1.0.0",
  "description": "A clean, minimal new tab with a focused search experience.",
  "permissions": ["clipboardRead"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "extension/icons/icon16.png",
    "48": "extension/icons/icon48.png",
    "128": "extension/icons/icon128.png"
  }
}
